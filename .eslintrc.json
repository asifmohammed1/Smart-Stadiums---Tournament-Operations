{
  "env": {
    "browser": true,
    "es2022": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "script"
  },
  "rules": {
    "no-var": "error",
    "prefer-const": "error",
    "no-unused-vars": ["error", { "vars": "local", "argsIgnorePattern": "^_" }],
    "no-undef": "warn",
    "eqeqeq": ["error", "always"],
    "curly": ["error", "all"],
    "no-eval": "error",
    "no-implied-eval": "error",
    "no-new-func": "error",
    "no-script-url": "error",
    "no-alert": "warn",
    "no-console": "off",
    "strict": ["error", "global"],
    "no-duplicate-case": "error",
    "no-unreachable": "error",
    "no-empty": "error",
    "consistent-return": "warn",
    "no-shadow": "warn",
    "prefer-template": "error",
    "object-shorthand": "error",
    "arrow-body-style": ["error", "as-needed"],
    "no-param-reassign": "warn",
    "max-len": ["warn", { "code": 120, "ignoreComments": true, "ignoreStrings": true, "ignoreTemplateLiterals": true }],
    "max-lines-per-function": ["warn", { "max": 50, "skipComments": true, "skipBlankLines": true }]
  },
  "globals": {
    "CONFIG_VERSION": "readonly",
    "TIME_MS": "readonly",
    "GEMINI_CONFIG": "readonly",
    "SAFETY_SETTINGS": "readonly",
    "STADIUM_SYSTEM_PROMPT": "readonly",
    "DEMO_RESPONSES": "readonly",
    "LANGUAGES": "readonly",
    "VENUES": "readonly",
    "CROWD_ZONES": "readonly",
    "ALERT_TEMPLATES": "readonly",
    "GA_MEASUREMENT_ID": "readonly",
    "GTM_ID": "readonly",
    "gtag": "readonly",
    "showToast": "readonly",
    "removeToast": "readonly",
    "animateCounter": "readonly",
    "initUI": "readonly",
    "scrollSection": "readonly",
    "cycleLang": "readonly",
    "getCurrentLangIndex": "readonly",
    "stopLiveClock": "readonly",
    "sanitiseInput": "readonly",
    "formatMessage": "readonly",
    "findDemoResponse": "readonly",
    "callGeminiAPI": "readonly",
    "appendMessage": "readonly",
    "showTypingIndicator": "readonly",
    "getAIReply": "readonly",
    "sendMessage": "readonly",
    "sendQuickPrompt": "readonly",
    "openAIAssistant": "readonly",
    "handleChatKey": "readonly",
    "initGemini": "readonly",
    "showZoneInfo": "readonly",
    "aiRecommendAction": "readonly",
    "sendAlert": "readonly",
    "initCrowd": "readonly",
    "addDemoAlert": "readonly",
    "approveTask": "readonly",
    "rejectTask": "readonly",
    "initAlerts": "readonly",
    "selectVenue": "readonly",
    "searchVenue": "readonly",
    "openGoogleMaps": "readonly",
    "selectTransport": "readonly",
    "initNavigation": "readonly",
    "addKeyboardActivation": "readonly",
    "getCountdown": "readonly",
    "AI_ERROR": "readonly",
    "FETCH_TIMEOUT_MS": "readonly",
    "RESPONSE_CACHE_MAX": "readonly",
    "STATUS_LABELS": "readonly",
    "runTests": "readonly",
    "TestRunner": "readonly"
  }
}
