{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "checkJs": true,
    "allowJs": true,
    "strict": false,
    "noImplicitAny": false,
    "noUnusedLocals": true,
    "noUnusedParameters": false,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "moduleResolution": "node",
    "module": "none",
    "baseUrl": ".",
    "paths": {}
  },
  "include": [
    "js/**/*.js",
    "sw.js",
    "tests/**/*.js"
  ],
  "exclude": [
    "node_modules"
  ]
}
